	<a class="page_prev" href="<%- url_for(page.prev_link) %>">
        < 上一篇：<%- page.prev.title %>
    </a>
	<% } %> 
    
    <% if (page.next) { %>
	<a class="page_next" href="<%- url_for(page.next_link) %>">
        下一篇：<%- page.next.title %> >
    </a>
	<% }%>
</div>
